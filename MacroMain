local toggleBind = Instance.new("TextButton") toggleBind.Size, toggleBind.Position = UDim2.new(0, 110, 0, 28), UDim2.new(1, -120, 0.5, -14) toggleBind.BackgroundColor3, toggleBind.Text, toggleBind.TextColor3 = Color3.fromRGB(50,50,55), "[ Insert ]", Color3.fromRGB(255,255,255) toggleBind.Parent = toggleRow Instance.new("UICorner").Parent = toggleBind

local checkingToggle = false
toggleBind.MouseButton1Click:Connect(function() checkingToggle = true toggleBind.Text = "...Press..." end)
UserInputService.InputBegan:Connect(function(input)
    if checkingToggle then checkingToggle = false
        if input.KeyCode ~= Enum.KeyCode.Escape then toggleHubHotkey = input.KeyCode end
        toggleBind.Text = "[ " .. toggleHubHotkey.Name .. " ]"
    end
end)

local scaleHubRow = createRow(settingsPage, "Hub Visual Scale")
local sHubFrame = Instance.new("Frame") sHubFrame.Size, sHubFrame.Position = UDim2.new(0, 140, 0, 8), UDim2.new(1, -150, 0.5, -4) sHubFrame.BackgroundColor3 = Color3.fromRGB(40,40,45) sHubFrame.Parent = scaleHubRow
local sHubBtn = Instance.new("TextButton") sHubBtn.Size, sHubBtn.Position = UDim2.new(0, 16, 0, 16), sHubBtn.Position = UDim2.new(0.5, -8, 0.5, -8) sHubBtn.BackgroundColor3, sHubBtn.Text = Color3.fromRGB(255,200,50), "" sHubBtn.Parent = sHubFrame Instance.new("UICorner").Parent = sHubBtn

local slidingHub = false
sHubBtn.MouseButton1Down:Connect(function() slidingHub = true end)
mouse.Move:Connect(function()
    if slidingHub then
        local percentage = math.clamp((mouse.X - sHubFrame.AbsolutePosition.X) / sHubFrame.AbsoluteSize.X, 0, 1)
        sHubBtn.Position = UDim2.new(percentage, -8, 0.5, -8)
        HubScale.Scale = 0.6 + (percentage * 0.8) 
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then slidingHub = false end end)

local scaleBtnRow = createRow(settingsPage, "Float Button Scale")
local sBtnFrame = Instance.new("Frame") sBtnFrame.Size, sBtnFrame.Position = UDim2.new(0, 140, 0, 8), UDim2.new(1, -150, 0.5, -4) sBtnFrame.BackgroundColor3 = Color3.fromRGB(40,40,45) sBtnFrame.Parent = scaleBtnRow
local sBtnBtn = Instance.new("TextButton") sBtnBtn.Size, sBtnBtn.Position = UDim2.new(0, 16, 0, 16), sBtnBtn.Position = UDim2.new(0.5, -8, 0.5, -8) sBtnBtn.BackgroundColor3, sBtnBtn.Text = Color3.fromRGB(255,200,50), "" sBtnBtn.Parent = sBtnFrame Instance.new("UICorner").Parent = sBtnBtn

local slidingBtn = false
sBtnBtn.MouseButton1Down:Connect(function() slidingBtn = true end)
mouse.Move:Connect(function()
    if slidingBtn then
        local percentage = math.clamp((mouse.X - sBtnFrame.AbsolutePosition.X) / sBtnFrame.AbsoluteSize.X, 0, 1)
        sBtnBtn.Position = UDim2.new(percentage, -8, 0.5, -8)
