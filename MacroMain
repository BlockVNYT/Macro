local function showToast(message)
    local ui = CoreGui:FindFirstChild("MacroSystem")
    if ui and ui:FindFirstChild("MainFrame") and ui.MainFrame:FindFirstChild("ToastLabel") then
        ui.MainFrame.ToastLabel.Text = "[LOG]: " .. tostring(message)
    end
end

local function recordAction(actionTable)
    if not isRecording or isPlaying then return end
    if actionTable.Type == "KeyDown" or actionTable.Type == "KeyUp" then
        if actionTable.KeyCode == recordHotkey or actionTable.KeyCode == playHotkey or actionTable.KeyCode == toggleHubHotkey then return end
    end
    local currentTime = tick()
    actionTable.Delay = (lastActionTime == 0) and 0 or (currentTime - lastActionTime)
    lastActionTime = currentTime
    table.insert(macroData, actionTable)
end

-- Input Listeners
UserInputService.InputBegan:Connect(function(input, processed)
    local keyCode = input.KeyCode
    if keyCode == Enum.KeyCode.Unknown then return end
    if keyCode == recordHotkey then _G.ToggleRecordTrigger() return
    elseif keyCode == playHotkey then _G.TogglePlayTrigger() return
    elseif keyCode == toggleHubHotkey then _G.ToggleHubVisibility() return end
    
    if isRecording and not isPlaying and not processed then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            recordAction({ Type = "KeyDown", KeyCode = keyCode })
            showToast("Key Pressed: " .. keyCode.Name)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, processed)
    local keyCode = input.KeyCode
    if keyCode == recordHotkey or keyCode == playHotkey or keyCode == toggleHubHotkey then return end
    if isRecording and not isPlaying and not processed then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            recordAction({ Type = "KeyUp", KeyCode = keyCode })
            showToast("Key Released: " .. keyCode.Name)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if not isRecording or isPlaying then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and not processed then
        recordAction({ Type = "MouseDown", X = mouse.X, Y = mouse.Y + 36 })
        showToast("Mouse Down at X: " .. mouse.X .. " Y: " .. mouse.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input, processed)
    if not isRecording or isPlaying then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 and not processed then
        recordAction({ Type = "MouseUp", X = mouse.X, Y = mouse.Y + 36 })
        showToast("Mouse Up at X: " .. mouse.X .. " Y: " .. mouse.Y)
    end
end)

