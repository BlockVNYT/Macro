_G.TogglePlayTrigger = function()
    if isRecording then return end
    isPlaying = not isPlaying
    
    if isPlaying then
        if #macroData == 0 then showToast("Error: No macro loaded or cached!") isPlaying = false return end
        playBtn.Text, playBtn.BackgroundColor3 = "⏹️ Stop", Color3.fromRGB(200, 120, 30)
        showToast("Replaying macro...")
        
        task.spawn(function()
            local loopCount = 0
            local startTime = tick()
            
            while isPlaying do
                for i, action in ipairs(macroData) do
                    if not isPlaying then break end
                    if action.Delay and action.Delay > 0 then task.wait(action.Delay) else task.wait(0.001) end
                    
                    if action.Type == "MouseDown" then
                        if mousemoveabs then mousemoveabs(action.X, action.Y) task.wait(0.01) end
                        VirtualInputManager:SendMouseButtonEvent(action.X, action.Y, 0, true, game, 1)
                    elseif action.Type == "MouseUp" then
                        if mousemoveabs then mousemoveabs(action.X, action.Y) task.wait(0.01) end
                        VirtualInputManager:SendMouseButtonEvent(action.X, action.Y, 0, false, game, 1)
                    elseif action.Type == "KeyDown" then 
                        local k = typeof(action.KeyCode) == "string" and Enum.KeyCode[action.KeyCode] or action.KeyCode
                        VirtualInputManager:SendKeyEvent(true, k, false, game)
                    elseif action.Type == "KeyUp" then 
                        local k = typeof(action.KeyCode) == "string" and Enum.KeyCode[action.KeyCode] or action.KeyCode
                        VirtualInputManager:SendKeyEvent(false, k, false, game) 
                    end
                end
                
                loopCount = loopCount + 1
                if repeatMode == "Times" and loopCount >= targetMaxCount then break
                elseif repeatMode == "Time" then
                    local totalAllowedSeconds = (targetHours * 3600) + (targetMinutes * 60) + targetSeconds
                    if (tick() - startTime) >= totalAllowedSeconds then break end
                end
                task.wait(math.max(loopInterval, 0.01))
            end
            isPlaying = false
            playBtn.Text, playBtn.BackgroundColor3 = "▶️ Replay", Color3.fromRGB(50, 150, 50)
            showToast("Playback completed.")
        end)
    else
        isPlaying = false
        playBtn.Text, playBtn.BackgroundColor3 = "▶️ Replay", Color3.fromRGB(50, 150, 50)
    end
end
playBtn.MouseButton1Click:Connect(_G.TogglePlayTrigger)

